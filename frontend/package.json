{
  "name": "ai-tv",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.cyberculturecorp.aitv",
    "productName": "AI-TV",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "serve-static": "^2.2.1"
  }
}
